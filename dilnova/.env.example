# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?sslmode=require"

# Clerk Authentication Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."

# Frontend Application URL (email links, canonical URLs)
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Cloudinary — signed uploads (no public upload preset)
# Keys: https://console.cloudinary.com/settings/api-keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Optional: detailed /api/health probe (Authorization: Bearer <secret>)
HEALTH_CHECK_SECRET="generate_a_long_random_secret"

# Supabase Storage (private payment slips)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Rate limiting (required in production)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# SMTP Relay (e.g. Brevo)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your_smtp_login_email@example.com"
SMTP_PASSWORD="your_smtp_relay_password"

# Sender Configuration
EMAIL_FROM_ADDRESS="info@yourdomain.com"
EMAIL_FROM_NAME="Your Company Commerce"

# Optional: Clerk user IDs allowed as platform superadmin (comma-separated)
SUPERADMIN_USER_IDS="user_abc123,user_def456"

# E2E tests only (local / CI — not required for production runtime)
E2E_VENDOR_ADMIN_EMAIL=""
E2E_VENDOR_MEMBER_EMAIL=""
E2E_CUSTOMER_EMAIL=""
E2E_SUPERADMIN_EMAIL=""

# REMOVED — do not use (unsigned upload preset replaced by signed uploads):
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET
