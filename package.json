{
  "name": "dilnova",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "resolutions": {
    "postcss": ">=8.5.10",
    "js-cookie": ">=3.0.6",
    "esbuild": "^0.28.1",
    "brace-expansion": ">=1.1.16",
    "sharp": ">=0.35.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/pre-launch-check.mjs && pnpm run lint && pnpm exec tsc --noEmit && vitest run && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit --audit-level=low",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze:bundle": "node scripts/analyze-bundle-size.mjs",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node ./node_modules/@playwright/test/cli.js test --ui",
    "test:e2e:install": "node ./node_modules/@playwright/test/cli.js install chromium",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:verify": "node scripts/verify-migrations.mjs",
    "db:backup": "node scripts/backup-db.mjs",
    "db:restore": "node scripts/restore-db.mjs",
    "pre-launch": "node scripts/pre-launch-check.mjs",
    "prepare": "node scripts/setup-git-hooks.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "7.5.20",
    "@sentry/nextjs": "^10.67.0",
    "@supabase/supabase-js": "2.110.3",
    "@upstash/qstash": "^2.11.2",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-cloudinary": "6.17.5",
    "next-safe-action": "^8.6.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "schema-dts": "^2.0.0",
    "serialize-javascript": "^7.0.7",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.7",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/serialize-javascript": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-filenames": "^1.3.2",
    "prettier": "^3.5.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
