Author: Diluka Lahiru <106172155+dilukalahiru@users.noreply.github.com>
Date:   Tue Jun 23 18:27:21 2026 +0530

    feat: add automated smoke test workflow for post-deployment health verification

diff --git a/.github/workflows/smoke-test.yml b/.github/workflows/smoke-test.yml
new file mode 100644
index 0000000..5f5ba3f
--- /dev/null
+++ b/.github/workflows/smoke-test.yml
@@ -0,0 +1,54 @@
+name: Post-Deploy Smoke Test
+
+on:
+  deployment_status:
+  workflow_dispatch:
+    inputs:
+      target_url:
+        description: 'Target URL to run smoke tests against'
+        required: true
+        default: 'https://www.dilstar.pp.ua'
+
+jobs:
+  health-probe:
+    name: Detailed Production Environment Probe
+    # Run if triggered manually OR if a Vercel deployment just finished successfully
+    if: github.event_name == 'workflow_dispatch' || github.event.deployment_status.state == 'success'
+    runs-on: ubuntu-latest
+    steps:
+      - name: Validate Environment configuration
+        run: |
+          TARGET_URL="${{ github.event.inputs.target_url || github.event.deployment_status.target_url }}"
+          
+          if [ -z "$TARGET_URL" ]; then
+            echo "No target URL provided"
+            exit 1
+          fi
+          
+          echo "Running detailed health probe against $TARGET_URL/api/health"
+          
+          # Run the authenticated detailed health probe to check DB and Redis
+          HTTP_STATUS=$(curl -s -o health.json -w "%{http_code}" -H "Authorization: Bearer ${{ secrets.HEALTH_CHECK_SECRET }}" "$TARGET_URL/api/health")
+          
+          if [ "$HTTP_STATUS" != "200" ]; then
+            echo "❌ Detailed health probe failed! Received HTTP $HTTP_STATUS"
+            cat health.json
+            exit 1
+          fi
+          
+          # Parse JSON payload
+          APP_STATUS=$(jq -r '.status' health.json)
+          DB_STATUS=$(jq -r '.database' health.json)
+          RL_STATUS=$(jq -r '.rateLimit.status' health.json)
+          
+          echo "App Status: $APP_STATUS"
+          echo "DB Status: $DB_STATUS"
+          echo "Rate Limit Status: $RL_STATUS"
+          
+          if [ "$APP_STATUS" != "ok" ] || [ "$DB_STATUS" != "connected" ]; then
+            echo "❌ Environment is misconfigured or degraded!"
+            cat health.json
+            exit 1
+          fi
+          
+          echo "✅ Production environment verification passed successfully."

