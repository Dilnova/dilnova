diff --git a/.github/workflows/uptime-monitor.yml b/.github/workflows/uptime-monitor.yml
new file mode 100644
index 0000000..6949b1b
--- /dev/null
+++ b/.github/workflows/uptime-monitor.yml
@@ -0,0 +1,69 @@
+name: Uptime Monitor
+
+on:
+  schedule:
+    # Run every 5 minutes
+    - cron: '*/5 * * * *'
+  workflow_dispatch:
+    inputs:
+      target_url:
+        description: 'URL to ping (override)'
+        required: false
+        type: string
+
+jobs:
+  health-check:
+    runs-on: ubuntu-latest
+    timeout-minutes: 5
+
+    steps:
+      - name: Ping API Health Endpoint
+        id: ping
+        env:
+          # Use workflow input if provided, otherwise fallback to the production URL variable, 
+          # or finally default to dilstar.pp.ua which is referenced in layout.tsx.
+          TARGET_URL: ${{ inputs.target_url || vars.PRODUCTION_APP_URL || 'https://dilstar.pp.ua' }}
+          HEALTH_SECRET: ${{ secrets.HEALTH_CHECK_SECRET }}
+        run: |
+          echo "Pinging health endpoint at $TARGET_URL/api/health"
+          
+          if [ -n "$HEALTH_SECRET" ]; then
+            echo "Using authorized detailed probe"
+            RESPONSE=$(curl -s -w "\n%{http_code}" -H "Authorization: Bearer $HEALTH_SECRET" "$TARGET_URL/api/health")
+          else
+            echo "Using public probe"
+            RESPONSE=$(curl -s -w "\n%{http_code}" "$TARGET_URL/api/health")
+          fi
+          
+          HTTP_BODY=$(echo "$RESPONSE" | sed '$d')
+          HTTP_STATUS=$(echo "$RESPONSE" | tail -n1)
+          
+          echo "Status Code: $HTTP_STATUS"
+          echo "Response Body: $HTTP_BODY"
+          
+          if [ "$HTTP_STATUS" -ne 200 ]; then
+            echo "::error title=Health Check Failed::The health endpoint returned status $HTTP_STATUS"
+            exit 1
+          fi
+          
+          # Optional: Parse JSON to check internal detailed status if authorized
+          if echo "$HTTP_BODY" | grep -q '"status":"degraded"'; then
+            echo "::warning title=System Degraded::The health check returned 200 but system is in a degraded state (e.g. Upstash rate limiting failed)."
+            # We don't exit 1 here unless we want degraded states to wake people up
+          fi
+
+      - name: Notify on Failure
+        if: failure()
+        uses: dawidd6/action-send-mail@v3
+        with:
+          server_address: smtp.gmail.com
+          server_port: 465
+          username: ${{ secrets.MAIL_USERNAME }}
+          password: ${{ secrets.MAIL_PASSWORD }}
+          subject: 🚨 Uptime Monitor Failed! 
+          body: |
+            The production health check endpoint returned a non-200 status code. 
+            View the workflow run here: https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}
+          to: alerts@dilnova.com
+          from: GitHub Actions
+        continue-on-error: true # Don't fail the workflow if email fails, the GitHub Action failure notification will still trigger.

