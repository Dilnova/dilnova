# ═══════════════════════════════════════════════════════════════
# DILNOVA — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file as:
#   .env.local        → for local development
#   .env.preview      → for Vercel preview environments (sync to Vercel env vars)
#   .env.production   → for Vercel production (sync to Vercel env vars)
# ═══════════════════════════════════════════════════════════════

# ── 1. CLERK AUTHENTICATION ──────────────────────────────────
# Dev: Use TEST keys (pk_test_, sk_test_) from Clerk Dev instance
# Prod: Use LIVE keys (pk_live_, sk_live_) from Clerk Prod instance
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ── 2. APPLICATION URL ───────────────────────────────────────
# Dev: http://localhost:3000
# Prod: https://www.yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── 3. DATABASE (Supabase Postgres) ──────────────────────────
# MIGRATION_DATABASE_URL → Direct connection (port 5432) for schema migrations
# DATABASE_URL           → Pooler/Transaction connection (port 6543) for app runtime
#
# Dev:  Both can use pooler since the dev DB has less traffic
# Preview: MUST use a separate Supabase project/branch to prevent polluting Prod data!
# Prod: MIGRATION must be direct (:5432), DATABASE must be pooler (:6543)
MIGRATION_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres"
DATABASE_URL="postgresql://postgres.your-project:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres"
# DATABASE_POOL_SIZE=5

# ── 3.1. DATABASE BACKUPS (S3 / Backblaze B2) ─────────────
# S3_BACKUP_BUCKET="dilnova-db-backups-prod"
# S3_BACKUP_ENDPOINT="https://s3.eu-central-003.backblazeb2.com" # (leave empty for AWS S3)
# S3_BACKUP_REGION="eu-central-003"
# S3_BACKUP_KEY_ID="your_backblaze_key_id"
# S3_BACKUP_SECRET_KEY="your_backblaze_application_key"

# ── 4. SUPABASE STORAGE (Payment Slips) ─────────────────────
# Each environment MUST use its own Supabase project
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# ── 5. PII ENCRYPTION ───────────────────────────────────────
# 256-bit key for encrypting customer PII (emails, names, addresses)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WARNING: Changing this key makes existing encrypted data unreadable!
PII_ENCRYPTION_KEY="your_pii_encryption_key"

# ── 6. CLOUDINARY (Media Uploads) ────────────────────────────
# Shared across environments (same cloud account is fine)
# Keys: https://console.cloudinary.com/settings/api-keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# ── 7. UPSTASH REDIS (Rate Limiting) ────────────────────────
# Ideally separate databases per environment
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# ── 8. EMAIL / SMTP (Brevo) ─────────────────────────────────
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your_smtp_login@smtp-brevo.com"
SMTP_PASSWORD="your_smtp_relay_password"
EMAIL_FROM_ADDRESS="info@yourdomain.com"
EMAIL_FROM_NAME="Your Company"

# ── 9. HEALTH CHECK ─────────────────────────────────────────
# Secret for /api/health endpoint (Authorization: Bearer <secret>)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEALTH_CHECK_SECRET="generate_a_long_random_secret"

# ── 10. SUPERADMIN ACCESS ────────────────────────────────────
# Clerk User IDs with superadmin access (comma-separated)
# Dev and Prod Clerk instances have DIFFERENT user IDs!
# Find it at: Clerk Dashboard → Users → click your user → copy "User ID"
SUPERADMIN_USER_IDS="user_abc123"

# ── 11. ERROR MONITORING ────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── 12. CLOUDFLARE TURNSTILE (Spam Protection) ──────────────
# Testing credentials (always passes):
#   Sitekey:    1x00000000000000000000AA
#   Secret Key: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── 13. E2E TESTS & AUTOMATION ──────────────────────────────
# E2E_VENDOR_ADMIN_EMAIL=""
# E2E_VENDOR_MEMBER_EMAIL=""
# E2E_CUSTOMER_EMAIL=""
# E2E_SUPERADMIN_EMAIL=""
# VERCEL_AUTOMATION_BYPASS_SECRET=""

